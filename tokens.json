    "radius": {
      "sm":   "4px",
      "md":   "6px",
      "lg":   "8px",
      "xl":   "12px",
      "2xl":  "16px",
      "full": "9999px"
    },
    "duration": {
      "fast":   "100ms",
      "normal": "200ms",
      "slow":   "300ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "enter":    "cubic-bezier(0, 0, 0.2, 1)",
      "exit":     "cubic-bezier(0.4, 0, 1, 1)"
    }
  },

