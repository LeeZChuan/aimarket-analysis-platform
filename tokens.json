      "letterSpacing": {
        "tight":  "-0.02em",
        "normal": "0",
        "wide":   "0.04em",
        "wider":  "0.08em"
      }
    },
    "spacing": {
      "0":  "0px",
      "1":  "4px",
      "2":  "8px",
      "3":  "12px",
      "4":  "16px",
      "5":  "20px",
      "6":  "24px",
      "8":  "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px"
