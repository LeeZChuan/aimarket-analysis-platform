      },
      "fontSize": {
        "xs":   "11px",
        "sm":   "12px",
        "base": "14px",
        "md":   "15px",
        "lg":   "16px",
        "xl":   "18px",
        "2xl":  "20px",
        "3xl":  "24px",
        "4xl":  "28px"
      },
      "fontWeight": {
        "regular": "400",
        "medium":  "500",
        "semibold":"600"
      },
      "lineHeight": {
        "tight":  "1.2",
        "normal": "1.5",
        "relaxed":"1.65"
